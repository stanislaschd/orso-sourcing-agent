# (le .env n'est jamais committé sur GitHub : voir .gitignore)

# Quel LLM utiliser : "anthropic", "openai" ou "mock" (mock = pas de clé, données simulées)
LLM_PROVIDER=mock

# Modèle (laisse vide pour le défaut du provider, ou mets un modèle courant)
# Anthropic ex : claude-sonnet-4-5   |   OpenAI ex : gpt-4o
LLM_MODEL=

# Clés API (remplis seulement celle du provider choisi)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# API Pappers (données légales/financières françaises). Gratuit avec crédits limités.
# Crée une clé sur https://www.pappers.fr/api . Laisse vide pour utiliser le CSV seed.
PAPPERS_API_KEY=
